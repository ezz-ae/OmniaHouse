# ─── AI · Google Gemini ────────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey  (Google AI Studio, free tier).
# When this is missing, every AI route falls back to deterministic mocks —
# the UI keeps working, just without live model output.
GOOGLE_API_KEY=
# GEMINI_API_KEY is read as an alias of GOOGLE_API_KEY for convenience.
# GEMINI_API_KEY=

# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from Supabase dashboard → Project Settings → API.
# SERVICE_ROLE_KEY is server-only — never expose to client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Session security ──────────────────────────────────────────────────────
# Static IP of the Dubai office. Used by middleware.ts to detect session drift.
OFFICE_IP=

# ─── Shopify (omniastores.ae, store ID 69433065630) ────────────────────────
# Admin API token from a custom app with read_products, write_draft_orders scope.
SHOPIFY_STORE_DOMAIN=omniastores.ae
SHOPIFY_ADMIN_TOKEN=

# ─── WooCommerce (omniastores.com on Kinsta) ───────────────────────────────
# Generated under WooCommerce → Settings → Advanced → REST API.
WOOCOMMERCE_URL=https://omniastores.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# ─── WhatsApp Desk · Cloud API (Meta) ──────────────────────────────────────
# Set these to take +971 56 547 8227 off the phone app and onto the Desk.
# Steps:
#   1. Meta Business Manager → Business verification
#   2. Create WhatsApp Business Account (WABA)
#   3. Add the number; Meta sends the OTP to verify
#   4. Get the four secrets below from the WABA dashboard
#   5. WHATSAPP_VERIFY_TOKEN is any random string you choose and also
#      paste into Meta's "Webhook → Verify token" field
#   6. Webhook callback URL in Meta:
#      https://<your-domain>/api/whatsapp/webhook
WHATSAPP_NUMBER=+971565478227
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
# Optional — pin a specific Graph API version. Default is v21.0.
# WHATSAPP_GRAPH_VERSION=v21.0

# ─── Hex (analyst dashboards) ──────────────────────────────────────────────
# Public embed URL of the Inventory parity notebook. Embedded inside the
# Inventory Room as a "Hex view" tab so the team sees the canonical
# analyst numbers without leaving OmniaHouse. NEXT_PUBLIC_ — exposed
# to the browser intentionally; the URL is already a public embed.
NEXT_PUBLIC_HEX_INVENTORY_URL=

# ─── Optional: BNPL providers ──────────────────────────────────────────────
TAMARA_API_KEY=
TABBY_API_KEY=
