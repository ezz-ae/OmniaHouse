# ─── AI · Google Gemini ────────────────────────────────────────────────────
# Get from https://aistudio.google.com/apikey  (Google AI Studio, free tier).
# When this is missing, every AI route falls back to deterministic mocks —
# the UI keeps working, just without live model output.
GOOGLE_API_KEY=
# GEMINI_API_KEY is read as an alias of GOOGLE_API_KEY for convenience.
# GEMINI_API_KEY=

# ─── Supabase ──────────────────────────────────────────────────────────────
# When you install the Vercel ↔ Supabase integration, every variable below
# is auto-injected by Vercel — you don't paste them by hand. For local dev,
# copy them from the Vercel project's Environment Variables tab into
# .env.local.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Prisma reads the database through pgbouncer (POOLING URL) and runs
# migrations through the direct connection (NON_POOLING URL). Both are
# auto-injected by the Vercel integration.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_URL=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Fallback Prisma connection string for local dev when not using the
# Vercel-injected POSTGRES_PRISMA_URL. lib/db/prisma.ts accepts either.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/omniahouse

# ─── Session security ──────────────────────────────────────────────────────
# Static IP of the Dubai office. Used by middleware.ts to detect session drift.
OFFICE_IP=
# Local/staging escape hatch while Supabase is not provisioned.
# Production blocks protected rooms when Supabase is missing unless this is true.
ALLOW_MOCK_AUTH=
# Server-side passkey for the brand entry. Do not expose as NEXT_PUBLIC.
HOUSE_PASSKEY=

# ─── Shopify (omniastores.ae, store ID 69433065630) ────────────────────────
# Admin API token from a custom app — Vercel app needs read+write scopes
# (read_products, read_customers, read_orders, write_draft_orders).
#
# IMPORTANT: keep a SEPARATE read-only token for Hex. The Hex notebook only
# needs read_products + read_customers + read_orders. Storing the writer
# token in Hex is unnecessary risk.
#
# Both SHOPIFY_ADMIN_ACCESS_TOKEN and SHOPIFY_ADMIN_TOKEN are accepted
# (lib/integrations/shopify.ts reads either) — pick one and stay consistent.
SHOPIFY_STORE_DOMAIN=omniastores.ae
SHOPIFY_ADMIN_TOKEN=
# SHOPIFY_ADMIN_ACCESS_TOKEN=

# ─── WooCommerce (omniastores.com on Kinsta) ───────────────────────────────
# Generated under WooCommerce → Settings → Advanced → REST API.
# Same rule as Shopify: Vercel gets a read+write key pair; Hex gets a
# separate READ-ONLY pair. Storing both in the same Hex Secrets pollutes
# the audit log.
WOOCOMMERCE_URL=https://omniastores.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# Hex notebook secrets (set under hex.tech Project → Secrets, NOT in this file):
#   SHOPIFY_READ_TOKEN, SHOPIFY_STORE_DOMAIN,
#   WOOCOMMERCE_READ_KEY,   WOOCOMMERCE_READ_SECRET, WOOCOMMERCE_URL
# The cells in hex/inventory-parity.yaml currently hit the unauthenticated
# public JSON endpoints; once those keys exist, replace the scrape requests
# with Admin/REST equivalents to get real stock_qty + private fields.

# ─── WhatsApp Desk · Cloud API (Meta) ──────────────────────────────────────
# Set these to take +971 56 547 8227 off the phone app and onto the Desk.
# Steps:
#   1. Meta Business Manager → Business verification
#   2. Create WhatsApp Business Account (WABA)
#   3. Add the number; Meta sends the OTP to verify
#   4. Get the four secrets below from the WABA dashboard
#   5. WHATSAPP_VERIFY_TOKEN is any random string you choose and also
#      paste into Meta's "Webhook → Verify token" field
#   6. Webhook callback URL in Meta:
#      https://<your-domain>/api/whatsapp/webhook
WHATSAPP_NUMBER=+971565478227
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
# Optional — pin a specific Graph API version. Default is v21.0.
# WHATSAPP_GRAPH_VERSION=v21.0

# ─── Hex (analyst dashboards) ──────────────────────────────────────────────
# Public embed URL of the Inventory parity notebook. Embedded inside the
# Inventory Room as a "Hex view" tab so the team sees the canonical
# analyst numbers without leaving OmniaHouse. NEXT_PUBLIC_ — exposed
# to the browser intentionally; the URL is already a public embed.
NEXT_PUBLIC_HEX_INVENTORY_URL=

# ─── Google Drive (Gemini Room source sets) ────────────────────────────────
# Used by the Management room integration sweep and the Gemini Room source
# set builder. When unset, Drive shows as "degraded" with a fix hint.
GOOGLE_DRIVE_CLIENT_ID=
# GOOGLE_DRIVE_CLIENT_SECRET=

# ─── Optional: BNPL providers ──────────────────────────────────────────────
TAMARA_API_KEY=
TABBY_API_KEY=
