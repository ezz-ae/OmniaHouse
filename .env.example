# ─── Supabase ──────────────────────────────────────────────────────────────
# Get these from Supabase dashboard → Project Settings → API.
# SERVICE_ROLE_KEY is server-only — never expose to client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Session security ──────────────────────────────────────────────────────
# Static IP of the Dubai office. Used by middleware.ts to detect session drift.
OFFICE_IP=

# ─── Shopify (omniastores.ae, store ID 69433065630) ────────────────────────
# Admin API token from a custom app with read_products, write_draft_orders scope.
SHOPIFY_STORE_DOMAIN=omniastores.ae
SHOPIFY_ADMIN_TOKEN=

# ─── WooCommerce (omniastores.com on Kinsta) ───────────────────────────────
# Generated under WooCommerce → Settings → Advanced → REST API.
WOOCOMMERCE_URL=https://omniastores.com
WOOCOMMERCE_CONSUMER_KEY=
WOOCOMMERCE_CONSUMER_SECRET=

# ─── AI (OpenAI, GPT-4o per the whatsapp-extraction spec) ──────────────────
OPENAI_API_KEY=

# ─── WhatsApp Desk ─────────────────────────────────────────────────────────
WHATSAPP_NUMBER=+971565478227

# ─── Optional: BNPL providers (V2) ─────────────────────────────────────────
TAMARA_API_KEY=
TABBY_API_KEY=
